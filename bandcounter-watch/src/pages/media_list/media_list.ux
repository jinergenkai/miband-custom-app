    padding: 0 15px;
    justify-content: space-between;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.05);
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  .title {
    font-size: 20px;
    font-weight: bold;
    color: #FFFFFF;
  }

  .sync-btn {
    padding: 6px 15px;
    background-color: #448AFF;
    border-radius: 12px;
  }

  .sync-text {
    font-size: 16px;
    font-weight: bold;
    color: #FFFFFF;
  }

  .media-list {
    flex: 1;
    width: 100%;
  }

  .item-control {
    width: 100%;
    padding: 15px 15px 5px 15px;
  }

  .stop-btn {
    width: 100%;
    height: 60px;
    background-color: #FF5252;
    border-radius: 15px;
    justify-content: center;
    align-items: center;
  }

  .stop-text {
    font-size: 18px;
    font-weight: bold;
    color: #FFFFFF;
  }

  .section-header {
    padding: 20px 20px 5px 20px;
  }

  .section-title {
    font-size: 16px;
    font-weight: bold;
    color: #448AFF;
  }

  .media-item {
    padding: 15px 20px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  .item-content {
    width: 100%;
    justify-content: space-between;
    align-items: center;
  }

  .item-name {
    font-size: 20px;
    color: #E2E8F0;
    flex: 1;
  }

  .play-icon {
    width: 20px;
    height: 20px;
    background-color: #448AFF;
    border-radius: 10px;
    margin-left: 10px;
  }

  .music-icon {
    background-color: #8B5CF6;
  }

  .empty-item {
    padding: 20px;
    justify-content: center;
  }

  .empty-text {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
  }

  .list-footer {
    padding: 50px 20px;
    justify-content: center;
  }

  .footer-text {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.2);
    text-align: center;
  }
</style>
