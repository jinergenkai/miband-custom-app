<template>
  <div class="container">
    <div class="header">
      <text class="title">MEDIA</text>
      <div class="sync-btn" onclick="requestMediaList">
        <text class="sync-text">SYNC</text>
      </div>
    </div>

    <list class="media-list">
      <list-item type="control" class="item-control">
        <div class="stop-btn" onclick="stopAll">
          <text class="stop-text">STOP ALL AUDIO</text>
        </div>
      </list-item>

      <!-- HYPE SECTION -->
      <list-item type="header" class="section-header">
        <text class="section-title">HYPE & SFX</text>
      </list-item>
      
      <list-item type="hype" for="{{ hypeList }}" class="media-item" onclick="playHype($item.id)">
        <div class="item-content">
          <text class="item-name">{{ $item.name }}</text>
          <div class="play-icon"></div>
        </div>
      </list-item>

      <list-item type="empty" if="{{ hypeList.length === 0 }}" class="empty-item">
        <text class="empty-text">Empty. Please tap SYNC.</text>
      </list-item>

      <!-- MUSIC SECTION -->
      <list-item type="header" class="section-header">
        <text class="section-title">MUSIC PLAYLIST</text>
      </list-item>

      <list-item type="music" for="{{ musicList }}" class="media-item" onclick="playMusic($item.id)">
        <div class="item-content">
          <text class="item-name">{{ $item.name }}</text>
          <div class="play-icon music-icon"></div>
        </div>
      </list-item>

      <list-item type="empty" if="{{ musicList.length === 0 }}" class="empty-item">
        <text class="empty-text">Empty. Please tap SYNC.</text>
      </list-item>

      <list-item type="footer" class="list-footer">
        <text class="footer-text">Swipe to go back</text>
      </list-item>
    </list>
  </div>
</template>

<script>
  import interconnect from '@system.interconnect'
  import prompt from '@system.prompt'
  import router from '@system.router'

  export default {
    private: {
      connect: null,
      musicList: [],
      hypeList: []
    },

    onInit() {
      this.connect = interconnect.instance()
      this.syncFromGlobal()
    },

    onShow() {
      this.setupConnect()
      this.syncFromGlobal()
      // Always request list when entering this screen to ensure fresh data
      this.requestMediaList()
    },

    syncFromGlobal() {
      if (this.$app.$def.musicList) {
        this.musicList = this.$app.$def.musicList
        console.info('⌚ [Media] Synced from global: ' + this.musicList.length + ' music')
      }
      if (this.$app.$def.hypeList) {
        this.hypeList = this.$app.$def.hypeList
        console.info('⌚ [Media] Synced from global: ' + this.hypeList.length + ' hype')
      }
    },

    setupConnect() {
      if (!this.connect) return
      
      this.connect.onmessage = (data) => {
        try {
          console.info('⌚ [Media] DATA: ' + data.data)
          const msg = JSON.parse(data.data)
          if (msg.action === 'media_list') {
            this.musicList = msg.music || []
            this.hypeList = msg.hype || []
            // Update global
            this.$app.$def.musicList = this.musicList
            this.$app.$def.hypeList = this.hypeList
            prompt.showToast({ message: 'List Updated: ' + (this.musicList.length + this.hypeList.length) })
          }
        } catch (e) {
          console.error('⌚ [Media] Parse error: ' + e.message)
        }
      }
    },

    onHide() {
      if (this.connect) {
        this.connect.onmessage = null
      }
    },

    requestMediaList() {
      if (!this.connect) return
      console.info('⌚ [Media] Requesting media list...')
      this.connect.send({
        data: { action: 'request_media_list' }
      })
      prompt.showToast({ message: 'Requesting...' })
    },

    playMusic(path) {
      if (!this.connect) return
      this.connect.send({
        data: { 
          action: 'play_music',
          id: path
        }
      })
      prompt.showToast({ message: 'Playing Music' })
    },

    playHype(id) {
      if (!this.connect) return
      this.connect.send({
        data: { 
          action: 'play_hype',
          id: id
        }
      })
      prompt.showToast({ message: 'Triggered Hype' })
    },

    stopAll() {
      if (!this.connect) return
      this.connect.send({
        data: { action: 'stop_all_media' }
      })
      prompt.showToast({ message: 'All Stopped' })
    }
  }
</script>

