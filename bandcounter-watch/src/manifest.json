{
  "package": "com.hung.bandcounter",
  "name": "BandCounter",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1100,
  "icon": "/common/icon.png",
  "deviceTypeList": ["watch"],
  "features": [
